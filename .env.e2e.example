# Playwright E2E-Testkonfiguration
# Kopieren Sie diese Datei nach .env.e2e und füllen Sie die Werte aus.
# .env.e2e wird von .gitignore ausgeschlossen – niemals einchecken.

# URL des laufenden Dev-Servers (Standard: http://localhost:5000)
E2E_BASE_URL=http://localhost:5000

# Anmeldedaten eines aktiven Testbenutzers (admin oder agent).
# Legen Sie diesen Benutzer in Ihrer Testdatenbank an.
E2E_ADMIN_EMAIL=admin@example.com
E2E_ADMIN_PASSWORD=sicheres-passwort
